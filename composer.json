{
    "name": "laravel/laravel",
    "type": "project",
    "version": "1.0",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-bcmath": "*",
        "ext-intl": "*",
        "ext-pcntl": "*",
        "ext-sodium": "*",
        "ext-zip": "*",
        "cybercog/laravel-ban": "^4.11",
        "filament/filament": "^5.0",
        "filament/notifications": "^5.0",
        "flowframe/laravel-trend": "^0.5.0",
        "guzzlehttp/guzzle": "^7.2",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel-notification-channels/discord": "^1.5",
        "laravel-notification-channels/telegram": "^7.0",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.30",
        "laravel/nightwatch": "^1.8",
        "laravel/pulse": "^1.4",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^4.1",
        "socialiteproviders/pr0gramm": "^5.0",
        "spatie/browsershot": "^5.4",
        "tightenco/ziggy": "^2.0",
        "tschucki/laravel-notification-channel-pr0gramm": "^0.0.4"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2",
        "fakerphp/faker": "^1.23",
        "filament/upgrade": "^5.0",
        "laravel-lang/common": "^6.5",
        "laravel/boost": "^2.4",
        "laravel/dusk": "^8.3",
        "laravel/pint": "^1.18",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.5",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.5",
        "roave/security-advisories": "dev-latest",
        "spatie/laravel-ignition": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}
